  "literature": [
    { "jp": "むかしむかし、あるところに、おじいさんとおばあさんがいました。", "ro": "mukasimukasi,arutokoroni,ojiisantobaasangasimasita." },
    { "jp": "おじいさんはやまへしばかりに、おばあさんはかわへせんたくにいきました。", "ro": "ojiisanhayamahesibakarini,obaasanhakawahesentakuiniikimasita." },
    { "jp": "かわからおおきなももがどんぶらこどんぶらことながれてきました。", "ro": "kawakaraookinamomogadomburakodomburakotonagarete kimasita." },
    { "jp": "ももからうまれたももたろうは、おにがしまへたびだちました。", "ro": "momokaraumaretamomotarouha,onigasimahetabidacimasita." },
    { "jp": "きびだんごをひとつわたしにください。", "ro": "kibidangowohitotuwatasinikudasai." },
    { "jp": "いぬときじとさるがおともになりました。", "ro": "inutokijitosarugaotomoninarimasita." },
    { "jp": "めでたしめでたし。", "ro": "medetasimedetasi." },
    { "jp": "むかしむかし、うらしまというりょうしがいました。", "ro": "mukasimukasi,urasimatuiuryousigasimasita." },
    { "jp": "いじめられているかめをたすけてあげました。", "ro": "ijimerareteirukamewotasuketeagemasita." },
    { "jp": "かめにつれられてりゅうぐうじょうへいきました。", "ro": "kameniturerateruyuuguujouheiikimasita." },
    { "jp": "おとひめさまからたまてばこをもらいました。", "ro": "otohimesamakaratamatebakowomoraimasita." },
    { "jp": "けむりがでて、おじいさんになってしまいました。", "ro": "kemurigadete,ojiisanninattesimaimasita." },
    { "jp": "わがはいはねこである。なまえはまだない。", "ro": "wagahaihanecodearu.namaehamadanai." },
    { "jp": "どこでうまれたか、とんとけんとうがつかぬ。", "ro": "dokodeumaretaka,tontokentougatukanu." },
    { "jp": "めろすはげきどした。かならず、あのじゃちのうかんのわうのぞかなければならぬ。", "ro": "merosuhagekidosita.kanarazu,anojacinoukannowauwonozokanakelebanaranu." },
    { "jp": "めろすにはせいじがわからぬ。めろすは、むらのぼくじんである。", "ro": "merosunihaseijigawakaranu.merosusha,muranobokujindearu." },
    { "jp": "つれづれなるままに、ひぐらし、すずりにむかいて、", "ro": "turezurenarumamani,higurasi,suzurinimukaite," },
    { "jp": "こころにうつりゆくよしなしごとを、そこはかとなくかきつくれば、", "ro": "kokoroniuturiyukuyosinasigotowo,sokohakatonakukakitudureba," },
    { "jp": "あやしゅうこそものぐるおしけれ。", "ro": "ayasyuukosomonoguruosikere." },
    { "jp": "ゆくかわのながれはたえずして、しかももとのみずにあらず。", "ro": "yukukawanonagarehataezusite,sikamomotonomizuniarazu." },
    { "jp": "よどみにうかぶうたかたは、かつきえかつむすびて、ひさしくとどまりたるためしなし。", "ro": "yodominiukabuutakataha,katukiekatususubite,hisasikutodomaritartameinasi." },
    { "jp": "ぎおんしょうじゃのかねのこえ、しょぎょうむじょうのひびきあり。", "ro": "gionsyoujanokanenokoe,syogyoumujyounohibikiari." },
    { "jp": "さらのそうじゅのはなのいろ、じょうしゃひすいのことわりをあらわす。", "ro": "saranosoujyunohananoiro,jyousyahisuyinokotowariwoarawasu." },
    { "jp": "おごれるひともひさしからず、ただはるのよのゆめのごとし。", "ro": "ogoreruhitomohisasikarazu,tadaharunoyonoyumenogotosi." },
    { "jp": "たけきものもついにはほろびぬ、ひとえにかぜのまえのちりにおなじ。", "ro": "takekimonomotuinihahorobinu,hitoenikazenomaenotirinioonaji." },
    { "jp": "はるはあけぼの。ようようしろくなりゆくやまぎわ、すこしあかりて、", "ro": "haruhaakebono.youyousirokunariyukuyamagiwa,sukosiakarite," },
    { "jp": "むらさきだちたるくもの、ほそくなびきたる。", "ro": "murasakidacitarukumono,hosokunabikitaru." },
    { "jp": "なつはよる。つきのころはさらなり、やみもなお、ほたるのおおくちがいたる。", "ro": "natsuhamoru.tukinokorohasaranari,yamimonao,hotarunoookucigaitaru." },
    { "jp": "あきはゆうぐれ。ゆうひのさしてやまのはいとちかくなりたるに、", "ro": "akihayuugure.yuuhinosasiteyamanohaitocikakunaritari." },
    { "jp": "からすのねどころへいこうとて、みつよつ、ふたつみつなど、とびいそぐさえあわれなり。", "ro": "karasunonedokoroheikoutote,mituyotu,hutatumitunado,tobiisogusaeawareneri." },
    { "jp": "ふゆはつとめがた。ゆきのふりたるはいうべきにもあらず、", "ro": "huyuhatutomegata.yukinohuritaruhaiubekiniamoarazu," },
    { "jp": "しものいとしろきも、またさらでもいとあたたかに、", "ro": "simonoitosirokimo,matasarademoitoatatakahni," },
    { "jp": "ひをおこして、すみをもてわたるも、いとつきづきし。", "ro": "hiwookosite,sumiwomotewatarumo,itotukidukisi." },
    { "jp": "ひがおちて、すずしくなりゆくままに、", "ro": "higaotite,suzusikunariyukumamani," },
    { "jp": "むかし、おとこありけり。", "ro": "mukasi,otokoarikeri." },
    { "jp": "みやこにいとあやしきおとこありけり。", "ro": "miyakoniitoayasikiotokoarikeri." },
    { "jp": "としごろよくしあえるひとに、あたらしいてがみをかく。", "ro": "tosigoroyokusiaeruhitoni,atarasiitegamiwokaku." },
    { "jp": "くにとおくにありておもうもの。", "ro": "kunitookuniariteomoumono." },
    { "jp": "ふるいけやかわずとびこむみずのおと。", "ro": "huruikeyakarazutobikomumizunooto." },
    { "jp": "しずけさやいわにしみいるせみのこえ。", "ro": "sizukesayaiwanisimiiruseminokoe." },
    { "jp": "さみだれをあつめてはやしもがみがわ。", "ro": "samidarewoatumetehayasimogamigawa." },
    { "jp": "ちちははのしきりにこいしきよつゆかな。", "ro": "ticihahanosikirinikoisikiyotuyukana." },
    { "jp": "ひまわりのはなきらきらとひをあびる。", "ro": "himawarinohanakirakirattohiwoabiru." },
    { "jp": "あきのたのかりのいおのまをあらみわがころもではつゆにぬれつつ。", "ro": "akinotanokarinoionomawobaramiwagakoromodehatuyuninurecutu." },
    { "jp": "はるすぎてなつきにけらししろたえのころもほすちょうあまのかぐやま。", "ro": "harusugitenatukinikerasisirotaenokoromohosucyouamanokaguyama." },
    { "jp": "あまのはらふりさけみればかすがなるみかさのやまにいでしつきかも。", "ro": "amanoharahurisakemirebakasuganarumikasanoyamaniidesitukikamo." },
    { "jp": "ひさかたのひかりのどけきはるのひにしづこころなくはなのちるらむ。", "ro": "hisakatanohikarinodokekiharunohinisiducokoronakuhananociruramu." },
    { "jp": "ちはやぶるかみよもきかずたつたがはからくれないにみづくくるとは。", "ro": "tihayaburukamiyomokikazutatutagahakarakurenainimizukukurutoha." },
    { "jp": "わがいおはみやこのたつみしかぞすむよをうぢやまにとひとはいふらむ。", "ro": "wagaiohamiyakonotatumisikazosumuyowoujiyamatohitohaihuramu." },
    { "jp": "あめふればそらもこころもくらくなり、", "ro": "amehurebasoramokokoromokurakunari," },
    { "jp": "それでもあしたをしんじていきていく。", "ro": "soredemoasitawoisnjiteikiteiku." }
  ]
}
