    { "jp": "ほうこく、れんらく、そうだんをおこなう。", "ro": "houkoku,renraku,soudanwookonau." },
    { "jp": "ぎょうむのこうりつかをおしすすめる。", "ro": "gyoumunokouritukawosisusumeru." },
    { "jp": "あたらしいあいであをだす。", "ro": "atarasiiaideawodasu." },
    { "jp": "もくひょうをたっせいする。", "ro": "mokuhyouwotasseisuru." },
    { "jp": "きゃりああっぷをめざす。", "ro": "kyariaappuwomezasu." },
    { "jp": "てれわーくをどうにゅうする。", "ro": "terewa-kuwodounyuusuru." },
    { "jp": "びじねすまなーをみにつける。", "ro": "bijinesumana-wominikuteru." },
    { "jp": "いんふらしすてむをこうちくする。", "ro": "inhurasisutemuwokoutikusuru." },
    { "jp": "でーたべーすにせつぞくする。", "ro": "de-tabe-sunisetusokusuru." },
    { "jp": "さーばーをきどうする。", "ro": "sa-ba-wokidousuru." },
    { "jp": "ねっとわーくのえらー。", "ro": "nettowa-kunoera-." },
    { "jp": "ういるすたいさくをほどこす。", "ro": "uirusutaisakuwohodosoku." },
    { "jp": "そふとうぇあのあっぷでーと。", "ro": "sofutoweanoappude-to." },
    { "jp": "うぇぶぶらうざをひらく。", "ro": "webuburauzawohiraku." },
    { "jp": "けんさくえんじんをつかう。", "ro": "kensakuenginwocukau." },
    { "jp": "さいとまっぷをさくせいする。", "ro": "saitomappuwosakuseisuru." },
    { "jp": "りんくをくりっくする。", "ro": "rinkuwokurikkusuru." },
    { "jp": "あぷりをだうんろーどする。", "ro": "apuriwodaunro-dosuru." },
    { "jp": "いんすとーるをかいしする。", "ro": "insuto-ruwokaisisuru." },
    { "jp": "あかねじゅん。", "ro": "akanejun." },
    { "jp": "あかうんとをせっていする。", "ro": "akauntowosetteisuru." },
    { "jp": "ろぐいんがせいこうした。", "ro": "roguingaseikousita." },
    { "jp": "ぱすわーどがちがいます。", "ro": "pasuwa-dogatigaimasu." },
    { "jp": "にだんかいにんしょうをおこなう。", "ro": "nidankaininsyouwookonau." },
    { "jp": "めーるのじゅしんぼっくす。", "ro": "me-runojusimbokkuus." },
    { "jp": "てんぷふぁいるをかくにんする。", "ro": "tempuhairuwokakunisuru." },
    { "jp": "めーりんぐりすとをさくせいする。", "ro": "me-ringurisutowosakuseisuru." },
    { "jp": "ちゃっとでれんらくする。", "ro": "cyattoderenrakusuru." },
    { "jp": "てれびかいぎにさんかする。", "ro": "terebikaiginisankasuru." },
    { "jp": "おんらいんのみーてぃんぐ。", "ro": "onrayinnomi-tingu." },
    { "jp": "がめんをきょうゆうする。", "ro": "gamenwokyouyuusuru." },
    { "jp": "まいくをみゅーとする。", "ro": "maikuwomyu-tosuru." },
    { "jp": "すぴーかーのおとをあげる。", "ro": "supi-ka-nootowoageru." },
    { "jp": "かめらをちぇっくする。", "ro": "kamerawoccekkusuru." },
    { "jp": "ぷろじぇくとまねーじゃー。", "ro": "purojekutomane-ja-." },
    { "jp": "しめきりをのばす。", "ro": "simekiriwonobasu." },
    { "jp": "よさんをけいさんする。", "ro": "yosanwokeisansuru." },
    { "jp": "こすとをさくげんする。", "ro": "kosutowosakugensuru." },
    { "jp": "うりあげをのばす。", "ro": "uriagewonobasu." },
    { "jp": "こきゃくのこうひょう。", "ro": "kokyakunokouhyou." },
    { "jp": "あたらしいていあんにかんしゃする。", "ro": "atarasiiteianninkansasuru." },
    { "jp": "しんきじぎょうをたちあげる。", "ro": "sinkijigyouwotaciageru." },
    { "jp": "ちーむのりーだー。", "ro": "ci-munori-da-." },
    { "jp": "こみゅにけーしょんをとる。", "ro": "komyunike-siyonwotoru." },
    { "jp": "いけんをこうかんする。", "ro": "ikenwokoukansuru." },
    { "jp": "あたらしいてくのろじーのべんきょう。", "ro": "atarasiitekunoroji-nobenkyou." },
    { "jp": "せいみつなけいかくをたてる。", "ro": "seimitunakeikakuwotateru." },
    { "jp": "じっけんをくりかえす。", "ro": "jikkenwokurikaesu." },
    { "jp": "けっかをぶんせきする。", "ro": "kekkawobunsekisuru." },
    { "jp": "ほうこくしょをさくせいする。", "ro": "houkokusyowosakuseisuru." },
    { "jp": "ぷれぜんのれんしゅうをする。", "ro": "puzenrorensyuuwosuru." },
    { "jp": "すらいどをさくせいする。", "ro": "suraidowosakuseisuru." },
    { "jp": "あいてむのせいりせいとん。", "ro": "aitemunoseiriseiton." },
    { "jp": "ですくのうえをかたづける。", "ro": "desukunouewokatadukeru." },
    { "jp": "じかんのしゅつにゅうをかんりする。", "ro": "jikaoshutunyuuwokanrisuru." },
    { "jp": "しごとのじゅんいをつける。", "ro": "sigotonojunyiwotukeru." },
    { "jp": "きょうのたすくをかんりょうする。", "ro": "kyounotasukuwokannryousuru." }
